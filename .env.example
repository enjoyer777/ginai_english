# =============================================================================
# school_english_pro AI bot — конфигурация
# Скопируйте этот файл в .env и заполните значениями. .env в git НЕ коммитится.
# =============================================================================

# === Telegram ===
# Создаётся в @BotFather командой /newbot
TG_BOT_TOKEN=

# chat_id группового чата менеджеров. Чтобы узнать: добавьте бота в чат,
# отправьте любое сообщение, посмотрите логи бота — он напечатает chat_id
# при первом апдейте из чата. ID групп всегда отрицательные (например -1001234567890).
MANAGERS_CHAT_ID=

# === OpenAI ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=600
OPENAI_TEMPERATURE=0.4

# === Yandex.Disk ===
# OAuth-токен Яндекс.Диска. Получается на https://yandex.ru/dev/disk/poligon/
# или через регистрацию приложения на https://oauth.yandex.ru/
YANDEX_DISK_OAUTH_TOKEN=

# Путь к xlsx-файлу на Я.Диске относительно корня (например /school_english_pro/kb.xlsx)
YANDEX_DISK_FILE_PATH=/school_english_pro/kb.xlsx

# Период кэширования базы знаний в секундах (FR-4.3: 5–10 мин)
KB_CACHE_TTL_SECONDS=600

# === Bitrix24 ===
# Полный URL входящего вебхука с правом crm.deal.* и crm.contact.*
# Пример: https://your-portal.bitrix24.ru/rest/1/abcdef1234567890/
BITRIX_WEBHOOK_URL=

# Стадия сделки по умолчанию (FR-6.1, R-7). У большинства порталов — NEW.
BITRIX_DEFAULT_STAGE=NEW

# Имя пользовательского поля сделки для дедупликации по Telegram user_id (FR-6.2).
# Поле создаётся вручную в Битрикс24 (тип "Строка") до первого запуска бота.
BITRIX_TG_USER_ID_FIELD=UF_CRM_TG_USER_ID

# === Storage ===
SQLITE_PATH=/data/state.db

# === Logging ===
LOG_LEVEL=INFO
LOG_PATH=/data/logs/bot.log

# === Misc ===
TIMEZONE=Europe/Moscow

# Дедуп уведомлений в чат менеджеров: повторно по тому же tg_user_id не шлём
# чаще, чем раз в N минут (FR-9.4).
NOTIFY_DEDUP_WINDOW_MINUTES=60

# Жёсткий лимит итераций tool-use в одном ответе LLM (защита от циклов).
LLM_MAX_TOOL_ITERATIONS=3

# Сколько последних пар user/assistant отдавать в LLM (R-5).
HISTORY_WINDOW_PAIRS=20
