{
  "_comment_": [
    "Шаблон Xray-клиент конфига для сайдкара бота.",
    "Скопируй в xray-config.json и подставь реальные значения от своего non-RU VPS.",
    "xray-config.json лежит в .gitignore — реальные UUID/ключи в репозиторий не попадут.",
    "Здесь дан пример VLESS+Reality. Для VMess/Trojan/Shadowsocks — поменяй блок 'outbounds[0]'",
    "по аналогии со своим клиентским конфигом (тот, которым ты подключаешься с ноута/телефона)."
  ],

  "log": { "loglevel": "warning" },

  "inbounds": [
    {
      "tag": "socks-in",
      "listen": "0.0.0.0",
      "port": 1080,
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": false
      }
    }
  ],

  "outbounds": [
    {
      "tag": "proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "194.87.54.138",
            "port": 36450,
            "users": [
              {
                "id": "4fd8a9f8-c2f2-4338-ba12-25b6af8720fe",
                "encryption": "none",
                "flow": "xtls-rprx-vision"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "www.microsoft.com",
          "fingerprint": "chrome",
          "publicKey": "",
          "shortId": "9a"
        }
      }
    },
    {
      "tag": "direct",
      "protocol": "freedom"
    },
    {
      "tag": "block",
      "protocol": "blackhole"
    }
  ],

  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "_comment": "Через non-RU VPS только то, что либо режется RU-провайдером (Telegram), либо блокируется на той стороне за RU-IP (OpenAI). Я.Диск и Битрикс — напрямую с RU VPS, не нагружаем non-RU и не добавляем латентность.",
        "type": "field",
        "domain": [
          "domain:telegram.org",
          "domain:t.me",
          "domain:telegra.ph",
          "domain:openai.com",
          "domain:oaistatic.com",
          "domain:oaiusercontent.com"
        ],
        "outboundTag": "proxy"
      },
      {
        "type": "field",
        "outboundTag": "direct",
        "network": "tcp,udp"
      }
    ]
  }
}
